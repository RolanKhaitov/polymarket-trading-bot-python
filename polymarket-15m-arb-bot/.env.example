# ──────────────────────────────────────────────────────────────────────────────
# Polymarket Favourite-Leg Bot — пример конфигурации
# Скопируйте в .env и отредактируйте под свои нужды
# ──────────────────────────────────────────────────────────────────────────────


# ── Режим бота ────────────────────────────────────────────────────────────────
#   dry   — симуляция (нет реальных ордеров, нет денег)
#   paper — виртуальные ордера по реальным ценам           ← по умолчанию
#   live  — реальная торговля (требует wallet + LIVE_TRADING_ENABLED=true)
BOT_MODE=paper


# ── Wallet credentials (только для BOT_MODE=live) ─────────────────────────────
# POLYMARKET_PRIVATE_KEY=0x...
# POLYMARKET_WALLET_ADDRESS=0x...
# POLYMARKET_PROXY_ADDRESS=0x...

# Дополнительные CLOB API ключи (если требуются)
# POLY_API_KEY=...
# POLY_API_SECRET=...
# POLY_API_PASSPHRASE=...


# ── Стратегия Favourite-Leg (Gabagool) — настроено под 5-минутные рынки ──────
#
# Логика: в последние MAX_SECONDS_TO_EXPIRY секунд 5-мин "Up or Down" рынка
# одна сторона (YES или NO) должна чётко выигрывать и торговаться ≥ 75¢.
# Мы ставим лимит на 3¢ ниже ask и ловим продавцов в панике.
#
# Пример сигнала (9:48 AM ET для рынка 9:45–9:50 AM ET):
#   Bitcoin Up or Down ... | YES=0.91 NO=0.10 | left=115s
#   → side=YES, limit=0.88, size=1 share, cost=$0.88, profit_if_win=$0.12

MAX_POSITION_SIZE=1            # USD на один рынок (1-10 для paper, осторожно с live)
MIN_FAVORITE_PRICE=0.75        # мин. цена фаворита (75¢) — ниже = больше сигналов, меньше edge
LIMIT_DISCOUNT=0.03            # скидка к ask (3¢) — наша limit_price = fav_ask - 0.03
MIN_LIQUIDITY_USD=5            # мин. ликвидность фаворита (USD); 5-мин рынки бывают тонкими
CANDIDATE_NEAR_DELTA=0.05      # зона кандидатов: (fav_thresh-5¢, fav_thresh)
MAX_CONCURRENT_POSITIONS=10    # макс. позиций одновременно


# ── Торговое окно ─────────────────────────────────────────────────────────────
# Для 5-мин рынков: endDate = конец 5-мин окна (напр. 9:50 AM ET)
# MAX_SECONDS_TO_EXPIRY=120 → входим в последние 2 минуты (9:48–9:50 AM ET)
# В это время направление уже известно и цены должны быть ≥75¢
MIN_SECONDS_TO_EXPIRY=10       # не входить если < N сек (слишком поздно для fill)
MAX_SECONDS_TO_EXPIRY=120      # входить только в последние 2 минуты


# ── Риск ──────────────────────────────────────────────────────────────────────
MAX_DAILY_LOSS=50              # USD — бот остановится при достижении


# ── Live safety (только для BOT_MODE=live) ────────────────────────────────────
# Обязательный opt-in — без этого live режим не запустится даже с credentials:
# LIVE_TRADING_ENABLED=true
#
# MAX_LIVE_ORDERS_PER_SESSION=20  # лимит ордеров за одну сессию
# MAX_LIVE_POSITION_USD=1         # жёсткий cap одной позиции (USD)
# KILL_SWITCH=false               # true = немедленно остановить live операции


# ── Источник данных ────────────────────────────────────────────────────────────
#   direct     — напрямую из Polymarket (по умолчанию, всегда работает)
#   monitoring — внешний monitoring-сервис (требует MONITORING_API_URL + MONITORING_WS_URL)
#   auto       — пробуем monitoring при старте; если недоступен — direct
DATA_SOURCE=direct

# Обязательны при DATA_SOURCE=monitoring или DATA_SOURCE=auto.
# MONITORING_API_URL  — REST endpoint (Gamma-совместимый формат)
# MONITORING_WS_URL   — WebSocket endpoint (Polymarket price_change/book формат)
MONITORING_API_URL=http://localhost:8000
MONITORING_WS_URL=ws://localhost:8000/ws
# MONITORING_PROBE_TIMEOUT=3.0
# MONITORING_GAMMA_URL=  ← legacy alias для MONITORING_API_URL (тоже работает)


# ── Технические настройки ──────────────────────────────────────────────────────
MARKET_REFRESH_INTERVAL=60    # обновлять список рынков каждые N сек
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING
