# ── Кошелёк (нужен только для live торговли) ──────────────────────────────
PRIVATE_KEY=0x...
WALLET_ADDRESS=0x...

# ── Polymarket API ключи (нужны только для live торговли) ─────────────────
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# ── Режим работы ──────────────────────────────────────────────────────────
DRY_RUN=true                   # true = симуляция, false = реальная торговля

# ── Торговые параметры ────────────────────────────────────────────────────
MAX_POSITION_SIZE=50.0         # Макс. размер позиции в USD на один рынок
MIN_PROFIT_PCT=0.02            # Мин. прибыль 2% (gross). После комиссий ~1%
MIN_LIQUIDITY_USD=50.0         # Мин. ликвидность на каждой стороне (YES/NO) в USD

# ── Риск менеджмент ───────────────────────────────────────────────────────
MAX_DAILY_LOSS=20.0            # Остановить бот при дневном убытке $
MAX_CONCURRENT_POSITIONS=5     # Макс. одновременных открытых позиций

# ── Таймауты ─────────────────────────────────────────────────────────────
MIN_SECONDS_TO_EXPIRY=30       # Не входить если до закрытия рынка < 30 сек
MAX_SECONDS_TO_EXPIRY=1000     # Не входить если до закрытия > 1000 сек (16 мин) — окно ещё не открылось
MARKET_REFRESH_INTERVAL=60     # Как часто обновлять список рынков (сек)

# ── Логи ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
